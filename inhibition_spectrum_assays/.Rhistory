collapsed <- read.csv("./collapsed_OTU5.csv")
stock <- read.csv("./in-80C.csv")
View(collapsed)
collapsed <- read.csv("./collapsed_OTU5.csv", header = FALSE)
View(collapsed)
stock <- read.csv("./in-80C.csv" header = FALSE)
View(stock)
stock <- read.csv("./in-80C.csv" header = FALSE)
View(collapsed)
View(stock)
collapsed <- read.csv("./collapsed_OTU5.csv", header = TRUE)
View(collapsed)
stock <- read.csv("./in-80C.csv" header = TRUE)
View(stock)
collapsed <- read.csv("./collapsed_OTU5.csv", header = TRUE)
stock <- read.csv("./in-80C.csv" header = TRUE)
stock <- read.csv("./in-80C.csv", header = TRUE)
View(stock)
merge(stock, collapsed, by.x = "Strain")
merge(stock, collapsed)
merged <- merge(stock, collapsed)
collapsed$Strain <- gsub("^.{0,4}", "", collapsed$Strain)
merged <- merge(stock, collapsed)
View(merged)
write.csv(merged, "./collapsed_stock.csv")
